<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit task</title>
</head>
<body style="display: flex; margin: 0; align-items: center; justify-content: center; height: 100vh; width: 100vw;">
        <form method="POST" style="display: flex; flex-direction: column; width: 30rem; align-items: center; background-color: rgba(209, 199, 199, 0.212); border-radius: 1rem; padding: 1rem; gap: 3px;">
        <label for="title">Title</label>
        <input type="text" name="title" id="title" value="<%=task.title%>"/>
        <label for="description">Description</label>
        <input type="text" name="description" id="description" value="<%=task.description%>" /> 
        <input hidden name="id" value='<%=task.id%>' />
        <button type="submit" style="margin: 1rem; width: 100px;">Edit</button>
    </form>
</body>
</html>